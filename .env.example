# Let's Pilates LA — environment variables
# Copy to .env.local for local dev; do NOT commit real values.

# ─── Public (safe to expose to the browser) ───────────────────────
# Inlined into the static build; readable by anyone who views source.
# RLS in Supabase is what keeps data safe — not these keys.

PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stage 1 MindBody bridge — booking CTAs point here until self-serve goes live.
PUBLIC_BOOKING_URL=


# ─── Server-only secrets (NEVER in the repo or browser) ──────────
# Configure inside the Supabase project: Settings → Edge Functions → Secrets
# (`supabase secrets set NAME=value`)
#
#   SUPABASE_SERVICE_ROLE        # full-access DB key, used inside Edge Functions only
#   STRIPE_SECRET_KEY            # Stripe API key for the server
#   STRIPE_WEBHOOK_SECRET        # verifies incoming Stripe webhook signatures
#   RESEND_API_KEY               # transactional email
